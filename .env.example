# Copy to .env and fill in real values. .env is gitignored.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-real-random-hex-string

# Optional. Defaults to sqlite:///app.db inside Flask's instance folder.
# DATABASE_URL=sqlite:///app.db

# Set to 1 in production (HTTPS only). Leave unset/0 in dev.
# SESSION_COOKIE_SECURE=0
